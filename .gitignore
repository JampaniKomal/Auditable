# Python
__pycache__/
*.py[cod]
*.so

# Environments
.env
.venv
env/
venv/
ENV/

# Docker / Database Data (Crucial so you don't commit the live fake DB)
scenarios/*/data/*
!scenarios/*/data/.gitkeep
scenarios/*/logs/*
!scenarios/*/logs/.gitkeep
scenarios/*/nginx/certs/*
!scenarios/*/nginx/certs/.gitkeep
scenarios/*/src/node_modules/
scenarios/*/elasticsearch/data/*
!scenarios/*/elasticsearch/data/.gitkeep
